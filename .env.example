# Environment variables template
# Copy this file to .env.local or .env.prod and fill in the values

# ============================================================================
# Environment
# ============================================================================
ENV=local  # local, staging, production
DEEPSEEK_API_KEY=deepseek_api_key
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-pro
AI_REQUEST_TIMEOUT_SECONDS=90
AI_REQUEST_MAX_ATTEMPTS=3
AI_REQUEST_RETRY_DELAY_SECONDS=5
SOURCE_CONFIG_OBJECT_KEY=configs/ingestion/source_config.json
# ============================================================================
# Airflow Configuration
# ============================================================================
AIRFLOW_IMAGE_NAME=apache/airflow:2.10.3
AIRFLOW_UID=50000
AIRFLOW_HOME=/opt/airflow
AIRFLOW_PROJ_DIR=.

# Airflow Web UI Credentials
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Airflow Settings
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW_OWNER=data-engineering
AIRFLOW_RETRIES=3
AIRFLOW_RETRY_DELAY_MINUTES=5

# Extra Python Dependencies
_PIP_ADDITIONAL_REQUIREMENTS=-r /project_root/requirements.txt

# ============================================================================
# DuckDB Configuration
# ============================================================================
DUCKDB_MEMORY_LIMIT=8GB
DUCKDB_THREADS=6
DUCKDB_MAX_MEMORY=4GB
DUCKDB_TEMP_DIR=/tmp/duckdb
DUCKDB_ENABLE_LOGGING=false
DUCKDB_ENABLE_PROFILING=false

# Iceberg Settings (Table Format)
DUCKDB_ICEBERG_ENABLED=true
DUCKDB_ICEBERG_FORMAT_VERSION=2
DUCKDB_ICEBERG_COMPRESSION=snappy
DUCKDB_ICEBERG_PARTITION_MODE=hive
DUCKDB_ICEBERG_FILE_FORMAT=parquet
DUCKDB_ICEBERG_TARGET_FILE_SIZE=134217728
DUCKDB_ICEBERG_METADATA_COMPRESSION=gzip
DUCKDB_ICEBERG_DELETE_MODE=copy-on-write

# ============================================================================
# S3/MinIO Configuration
# ============================================================================
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PATH_STYLE=true

# ============================================================================
# Iceberg Catalog Configuration
# ============================================================================
ICEBERG_CATALOG_URI=http://iceberg-rest:8181
ICEBERG_CATALOG_NAME=lakehouse

# ============================================================================
# Superset Configuration
# ============================================================================
SUPERSET_SECRET_KEY=change_me
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_FIRSTNAME=Superset
SUPERSET_ADMIN_LASTNAME=Admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_DB_HOST=superset-db
SUPERSET_DB_PORT=5432
SUPERSET_DB_NAME=superset
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset_password
POSTGRES_DB=superset
POSTGRES_USER=superset
POSTGRES_PASSWORD=superset_password
SUPERSET_REDIS_HOST=superset-redis
SUPERSET_REDIS_PORT=6379
SUPERSET_TRINO_DATABASE_NAME=Trino
SUPERSET_TRINO_SQLALCHEMY_URI=trino://admin@trino:8080/iceberg

# ============================================================================
# Bucket and Layer Paths
# ============================================================================
BUCKET=linkedin-jobs-prod
BRONZE_PATH=s3://linkedin-jobs-prod/bronze/crawler_data/linkedin/jobs
SILVER_PATH=s3://linkedin-jobs-prod/silver
GOLD_PATH=s3://linkedin-jobs-prod/gold/analytics

# ============================================================================
# Data Source Configuration
# ============================================================================
SOURCE_WEB_NAME=linkedin
ENTITY_TYPE=jobs
API_SOURCE_DIR=/project_root/tmp/api_sources
SCRAPPED_SOURCE_DIR=/project_root/tmp/scrapping_script

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# LinkedIn Credentials (if using real scraper)
# ============================================================================
USER_NAME=
PASSWORD=

# ============================================================================
# API Keys (if needed)
# ============================================================================
GEMINI_API_KEY=
