# ============================================================================
# User Credentials (for data generation)
# ============================================================================
USER_NAME=your_linkedin_username
PASSWORD=your_linkedin_password
GEMINI_API_KEY=your_gemini_api_key

# ============================================================================
# Airflow Configuration
# ============================================================================
AIRFLOW_IMAGE_NAME=apache/airflow:2.8.0-python3.11

# Permission setting (run 'id -u' to get your user ID)
AIRFLOW_UID=50000

# Docker group ID (run 'getent group docker | cut -d: -f3' to get your docker GID)
DOCKER_GID=989

# Optional Configurations
AIRFLOW__CORE__LOAD_EXAMPLES=false

# Default credentials for the Web UI
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
AIRFLOW_PROJ_DIR=./

# Extra Dependencies
_PIP_ADDITIONAL_REQUIREMENTS=

# ============================================================================
# DuckDB Configuration
# ============================================================================
DUCKDB_MEMORY_LIMIT=8GB
DUCKDB_THREADS=6
DUCKDB_MAX_MEMORY=4GB
DUCKDB_TEMP_DIR=/tmp/duckdb
DUCKDB_ENABLE_LOGGING=false
DUCKDB_ENABLE_PROFILING=false

# Iceberg Settings (Table Format) - CRITICAL
DUCKDB_ICEBERG_ENABLED=true
DUCKDB_ICEBERG_FORMAT_VERSION=2
DUCKDB_ICEBERG_COMPRESSION=snappy
DUCKDB_ICEBERG_PARTITION_MODE=hive
DUCKDB_ICEBERG_FILE_FORMAT=parquet
DUCKDB_ICEBERG_TARGET_FILE_SIZE=134217728
DUCKDB_ICEBERG_METADATA_COMPRESSION=gzip
DUCKDB_ICEBERG_DELETE_MODE=copy-on-write
DUCKDB_ICEBERG_PARTITION_COLUMNS=load_date

# ============================================================================
# MinIO/S3 Configuration
# ============================================================================
AWS_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=airflow-bucket
AWS_REGION=us-east-1

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PATH_STYLE=true

# ============================================================================
# Iceberg Catalog Configuration
# ============================================================================
ICEBERG_CATALOG_URI=postgresql://iceberg:iceberg123@postgres-iceberg:5432/iceberg_catalog
ICEBERG_WAREHOUSE_PATH=s3://iceberg-warehouse

# ============================================================================
# Bronze/Silver/Gold Layer Paths
# ============================================================================
BUCKET=airflow-bucket
BRONZE_PATH=s3://airflow-bucket/BRONZE/crawler_data/linkedin/jobs
SILVER_PATH=s3://airflow-bucket/silver
GOLD_PATH=s3://airflow-bucket/gold/analytics