USER_NAME=
PASSWORD=
GEMINI_API_KEY=

# --- Mandatory Settings ---
AIRFLOW_IMAGE_NAME=

# Permission setting
AIRFLOW_UID=

# --- Optional Configurations ---
AIRFLOW__CORE__LOAD_EXAMPLES=

# Default credentials for the Web UI
_AIRFLOW_WWW_USER_USERNAME=
_AIRFLOW_WWW_USER_PASSWORD=
AIRFLOW_PROJ_DIR=

# --- Extra Dependencies ---
_PIP_ADDITIONAL_REQUIREMENTS=

DUCKDB_MEMORY_LIMIT=8GB
DUCKDB_THREADS=6
DUCKDB_MAX_MEMORY=4GB
DUCKDB_TEMP_DIR=/tmp/duckdb
DUCKDB_ENABLE_LOGGING=false
DUCKDB_ENABLE_PROFILING=false

# Iceberg Settings (Table Format) - CRITICAL
DUCKDB_ICEBERG_ENABLED=true
DUCKDB_ICEBERG_FORMAT_VERSION=2
DUCKDB_ICEBERG_COMPRESSION=snappy
DUCKDB_ICEBERG_PARTITION_MODE=hive
DUCKDB_ICEBERG_FILE_FORMAT=parquet
DUCKDB_ICEBERG_TARGET_FILE_SIZE=134217728
DUCKDB_ICEBERG_METADATA_COMPRESSION=gzip
DUCKDB_ICEBERG_DELETE_MODE=copy-on-write
DUCKDB_ICEBERG_PARTITION_COLUMNS=load_date

# ============================================================================
# S3/MinIO Configuration
# ============================================================================

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PATH_STYLE=true

# ============================================================================
# Bronze/Silver/Gold Layer Paths
# ============================================================================

BUCKET=airflow-bucket
BRONZE_PATH=s3://airflow-bucket/BRONZE/crawler_data/linkedin/jobs
SILVER_PATH=s3://airflow-bucket/silver
GOLD_PATH=s3://airflow-bucket/gold/analytics