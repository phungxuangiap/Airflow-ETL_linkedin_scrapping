# Production Environment Configuration

ENV=production

# AI Selector Configuration
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=qwen/qwen3-32b

# Crawler Configuration
CRAWLER_REQUEST_DELAY_MIN_SECONDS=0
CRAWLER_REQUEST_DELAY_MAX_SECONDS=1
CRAWLER_PROXY_SWITCH_INTERVAL=100
CRAWLER_PROXIES=


# Airflow Configuration
AIRFLOW_IMAGE_NAME=apache/airflow:2.10.3
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=/opt/airflow
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=CHANGE_ME_IN_PRODUCTION
AIRFLOW__CORE__LOAD_EXAMPLES=false
_PIP_ADDITIONAL_REQUIREMENTS=
# DuckDB Configuration
DUCKDB_MEMORY_LIMIT=16GB
DUCKDB_THREADS=8
DUCKDB_MAX_MEMORY=8GB
DUCKDB_TEMP_DIR=/tmp/duckdb
DUCKDB_ENABLE_LOGGING=true
DUCKDB_ENABLE_PROFILING=false

# Iceberg Settings
DUCKDB_ICEBERG_ENABLED=true
DUCKDB_ICEBERG_FORMAT_VERSION=2
DUCKDB_ICEBERG_COMPRESSION=snappy
DUCKDB_ICEBERG_FILE_FORMAT=parquet
DUCKDB_ICEBERG_TARGET_FILE_SIZE=134217728

# S3/MinIO Configuration (Production - use real S3 or production MinIO)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PATH_STYLE=true

# Iceberg Catalog
ICEBERG_CATALOG_URI=postgresql://iceberg:iceberg123@postgres-iceberg:5432/iceberg_catalog
ICEBERG_CATALOG_NAME=lakehouse
ICEBERG_WAREHOUSE_PATH=s3://linkedin-jobs-prod/warehouse

# Superset Configuration
SUPERSET_SECRET_KEY=admin
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_FIRSTNAME=Superset
SUPERSET_ADMIN_LASTNAME=Admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_DB_HOST=superset-db
SUPERSET_DB_PORT=5432
SUPERSET_DB_NAME=superset
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=admin
POSTGRES_DB=superset
POSTGRES_USER=superset
POSTGRES_PASSWORD=admin
SUPERSET_REDIS_HOST=superset-redis
SUPERSET_REDIS_PORT=6379
SUPERSET_TRINO_DATABASE_NAME=Trino
SUPERSET_TRINO_SQLALCHEMY_URI=trino://admin@trino:8080/iceberg

# Bucket and Paths
BUCKET=linkedin-jobs-prod
BRONZE_PATH=s3://linkedin-jobs-prod/bronze/crawler_data/linkedin/jobs
SILVER_PATH=s3://linkedin-jobs-prod/silver
GOLD_PATH=s3://linkedin-jobs-prod/gold/analytics

# Data Source
SOURCE_WEB_NAME=linkedin
ENTITY_TYPE=jobs
SCRAPPED_SOURCE_DIR=/project_root/tmp/scrapping_script

# Logging
LOG_LEVEL=INFO
